// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client"
  output        = "./generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  username        String    @unique
  email           String    @unique
  password        String
  karma           Int       @default(0)
  karmaCount      Int       @default(0)
  isVerified      Boolean   @default(false)
  avatarUrl       String?
  phoneNumber     String?
  address         String?
  city            String?
  state           String?
  zip             String?
  country         String?
  latitude        Float?
  longitude       Float?
  items           Item[]
  borrowerRentals Rental[]  @relation("RentalBorrower")
  lenderRentals   Rental[]  @relation("RentalLender")
  sentMessages    Message[] @relation("MessageSender")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Item {
  id              String   @id @default(uuid())
  images          String[]
  title           String
  description     String
  dailyRate       Int
  securityDeposit Int
  lat             Float?
  lng             Float?
  isAvailable     Boolean  @default(true)
  specs           Json?
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id])
  rentals         Rental[] @relation("RentalItem")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Rental {
  id             String       @id @default(uuid())
  itemId         String
  borrowerId     String
  lenderId       String
  status         RentalStatus @default(PENDING)
  totalDays      Int
  itemDailyRate  Int
  pickupVideoUrl String?
  returnVideoUrl String?
  lastToken      String?
  activateTimer  DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  borrower       User         @relation("RentalBorrower", fields: [borrowerId], references: [id])
  item           Item         @relation("RentalItem", fields: [itemId], references: [id])
  lender         User         @relation("RentalLender", fields: [lenderId], references: [id])
  chats          Chat[]
}

model Chat {
  id        String    @id @default(uuid())
  rentalId  String    @unique
  rental    Rental    @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  senderId  String?
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender    User?    @relation("MessageSender", fields: [senderId], references: [id])
  content   String
  createdAt DateTime @default(now())
}

enum RentalStatus {
  PENDING
  APPROVED
  COMPLETED
  DISPUTED
}
